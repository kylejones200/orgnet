# Three E's + NetSmith ONA: keep NetSmith as its own repo (sibling to orgnet, or set NETSMITH_ROOT).
# Example: NETSMITH_ROOT=/path/to/netsmith  (tests prepend $NETSMITH_ROOT/src)

# Database Configuration
DATABASE_URL=sqlite:///orgnet.db
# For production, use PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/orgnet

# Optional: verbose logging in scripts
DEBUG=False

# Logging
LOG_LEVEL=INFO
