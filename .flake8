[flake8]
max-line-length = 100
ignore = E203, W503, E501, E266, E722, F401
exclude =
    .git,
    __pycache__,
    .pytest_cache,
    .mypy_cache,
    venv,
    env,
    build,
    dist,
    *.pyc,
    *.pyo

per-file-ignores =
    __init__.py:F401
    tests/three_es/*.py:E402,E712,F841
    scripts/three_es_examples.py:E402
